# sagarkapoor.eu — runtime configuration.
# Copy to `.env` for local dev; set these as environment variables on Cloudflare
# Pages for production. Nothing here is committed.

# ── Contact form (server-only) ──────────────────────────────────────────────
# Resend transactional API key.
NUXT_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Where contact submissions land. Single address or comma-separated list.
# This is the ONLY place Sagar's real inbox appears — never in the DOM.
NUXT_CONTACT_TO=you@private-inbox.example
# Verified Resend sender. The FROM domain must be verified in Resend; it does
# NOT need to match the site domain.
NUXT_CONTACT_FROM="Sagar Kapoor <noreply@verified-domain.example>"

# ── Cloudflare Turnstile (anti-spam) ────────────────────────────────────────
# Site key is public (rendered in the widget); secret is server-only and is read
# by @nuxtjs/turnstile as turnstile.secretKey.
NUXT_PUBLIC_TURNSTILE_SITE_KEY=0x4xxxxxxxxxxxxxxxxxxxxx
NUXT_TURNSTILE_SECRET_KEY=0x4xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# For local testing, Cloudflare's always-pass test keys work:
#   NUXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
#   NUXT_TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ── Writing ─────────────────────────────────────────────────────────────────
# No config needed. Blog posts are git-controlled markdown files in
# app/content/writing/*.md, rendered at build time. To publish, add a .md file
# with frontmatter (title, date, excerpt, tags) and commit.
